#!/usr/bin/env mishmaath
0
1 main
4 stdout
3 val 0
3 state 0
3 pin 3

2 "-- ADC read (literal pin) --"
10 val adc 3
2 "adc pin 3 = %d" val

2 "-- ADC read (variable pin) --"
10 val adc pin
2 "adc pin %d = %d" pin val

2 "-- GPIO set high --"
10 gpio set 5 1

2 "-- GPIO set low --"
10 gpio set 5 0

2 "-- GPIO get --"
10 state gpio get 5
2 "gpio pin 5 = %d" state

2 "-- loop: read ADC 5 times --"
3 i 0
9 i 0 5
  10 val adc 3
  2 "  tick %d: adc=%d" i val
9
7
